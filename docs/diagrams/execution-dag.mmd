    p2_loki["Loki"]
    p2_tempo["Tempo"]
    p2_prom["Prometheus"]
    p2_k8s["Kubernetes"]
    p2_gh["GitHub deploys"]
  end

  subgraph P3["Phase 3 — Agents (partial parallel)"]
    direction TB
    p3_intake["Intake"]
    p3_invest["Investigator"]
    p3_valid["Validator"]
