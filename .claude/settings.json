{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(task:*)",
      "Bash(kubectl get:*)",
      "Bash(kubectl describe:*)",
      "Bash(kubectl logs:*)",
      "Bash(kubectl top:*)",
      "Bash(kubectl config:*)",
      "Bash(kubectl cluster-info)",
      "Bash(kubectl api-resources:*)",
      "Bash(kubectl explain:*)",
      "Bash(kubectl rollout status:*)",
      "Bash(kubectl rollout history:*)",
      "Bash(kubectl port-forward:*)",
      "Bash(helm list:*)",
      "Bash(helm status:*)",
      "Bash(helm get:*)",
      "Bash(helm repo list)",
      "Bash(k3d cluster list)",
      "Bash(k3d registry list)",
      "Bash(docker ps:*)",
      "Bash(docker images:*)",
      "Bash(curl -s http://localhost:9090/api/v1/*)",
      "Bash(curl -s http://localhost:3100/loki/api/v1/*)"
    ],
    "deny": [
      "Bash(task cluster:nuke*)",
      "Bash(task cluster:down*)",
      "Bash(task monitoring:uninstall*)",
      "Bash(task demo:undeploy*)",
      "Bash(kubectl delete:*)",
      "Bash(kubectl drain:*)",
      "Bash(kubectl cordon:*)",
      "Bash(helm uninstall:*)",
      "Bash(k3d cluster delete:*)",
      "Bash(k3d registry delete:*)",
      "Bash(docker system prune:*)",
      "Bash(docker volume rm:*)"
    ]
  }
}
